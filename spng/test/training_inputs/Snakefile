rule linedepos:
    output:
        depos='linedepos-pdhd-plane{plane}-txz{txz}-ty{ty}_wct-depos.npz',
        meta='linedepos-pdhd-plane{plane}-txz{txz}-ty{ty}_wct-depos.json',
    params:
        offset="--offset '1*m,0*m,0*m'"
    shell: '''
    wcpy gen detlinegen \
    {params.offset} \
    --detector=pdhd \
    --plane={wildcards.plane} \
    --angle-coords=wire-plane \
    --theta_xz="{wildcards.txz}*deg" \
    --theta_y="{wildcards.ty}*deg" \
    --output_depos {output.depos} \
    --output_meta {output.meta}
    '''

rule linedepos_xzu_xzv:
    output:
        depos='linedepos-pdhd-plane{plane}-txzu{txzu}-txzv{txzv}_wct-depos.npz',
        meta='linedepos-pdhd-plane{plane}-txzu{txzu}-txzv{txzv}_wct-depos.json',
    params:
        offset="--offset '1*m,0*m,0*m'",
        xz_y = lambda w: xz_y_from_xzu_xzv_hyu(float(w.txzu), float(w.txzv)),
        
    shell: '''

    wcpy gen detlinegen \
    {params.offset} \
    --detector=pdhd \
    --plane={wildcards.plane} \
    --angle-coords=wire-plane \
    --theta_xz="{params.xz_y[0]}*deg" \
    --theta_y="{params.xz_y[1]}*deg" \
    --output_depos {output.depos} \
    --output_meta {output.meta}
    '''


    elif w.plane == 'v':
        angles = high_end_xzu_xzv_deg_vplane
    elif w.plane == 'w':
        angles = high_end_xzw_xzu_deg_wplane
    # else:
        # raise RuntimeError()
    res = [f'line-display-{w.plane}plane-t1_{t1}-t2_{t2}.pickle' for t1, t2 in angles]
    return res

all_theta_xz_deg=( 0,  1,  3,  5, 10, 20, 30, 45, 60, 75, 80, 82, 84, 89 )
all_planes = [0,1,2]

def same_thetaxz_plane_norm(txz, tyy):
    import numpy as np
    txz = txz*np.pi/180.
    tyy = tyy*np.pi/180.
    ret = np.array([1.,0.,0.])
    Ry = np.array([
        [np.cos(txz), 0, np.sin(txz)],
        [0.,1.,0.],
        [-np.sin(txz), 0, np.cos(txz)],
    ])
    Rx =  np.array([
        [1., 0., 0.],
        [0., np.cos(tyy), np.sin(tyy)],
        [0., -np.sin(tyy), np.cos(tyy)]
    ])

    return Rx @ (Ry @ ret)

def xz_y_from_samexz(v):
    import numpy as np
    y = np.acos(v[1])
    xz = np.asin(v[0]/np.sin(y))
    xz = xz*180./np.pi
    y = y*180./np.pi
    # print(f'{xzu},{xzv} --> {xz:.2f}, {y:.2f}') 
    return xz, y

def xz_y_from_xzw_xzu(xzw, xzu, tyy=35.7):
    import numpy as np
    vw = same_thetaxz_plane_norm(xzw, 0)
    vu = same_thetaxz_plane_norm(xzu, tyy)
    v = np.linalg.cross(vu, vw)
    v /= np.linalg.norm(v)
    xz, y = xz_y_from_samexz(v)
    print(f'{xzu},{xzv} --> {xz:.2f}, {y:.2f}') 
    return xz, y

def xz_y_from_xzu_xzv_hyu(xzu, xzv, tyy=-35.7):
    import numpy as np
    vu = same_thetaxz_plane_norm(xzu, tyy)
    vv = same_thetaxz_plane_norm(xzv, -tyy)
    v = np.linalg.cross(vv, vu)
    v /= np.linalg.norm(v)

    # y = np.acos(v[1])
    # xz = np.asin(v[0]/np.sin(y))
    # xz = xz*180./np.pi
    # y = y*180./np.pi
    xz, y = xz_y_from_samexz(v)
    print(f'{xzu},{xzv} --> {xz:.2f}, {y:.2f}') 
    return xz, y 


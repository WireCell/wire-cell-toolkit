def run_plot(angles):
    import torch
    import matplotlib.pyplot as plt
    import numpy as np
    all_effs = []
    all_purs = []

    xlabels = [f'{u},{v}' for u,v in angles]
    xpos = [i for i in range(len(xlabels))]

    ranges = [[0,800], [800,1600], [1600,2560]]
    for f in input:
        t = torch.load(f)
        labels = t['labels'][0].detach().cpu()
        y = t['y'][0].detach().cpu()

        for plane in params.test_tpcs:
            this_range = ranges[plane]
            real_pixels = torch.where(labels[this_range[0]:this_range[1]] > 0)
            eff = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/labels[this_range[0]:this_range[1]].sum()
            all_effs.append(eff)

            pur = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/(y[this_range[0]:this_range[1]] > .5).sum()
            all_purs.append(pur)
    print(all_effs)
    print(all_purs)

    plt.subplot(2, 1, 1)
    plt.plot(all_effs, label='Efficiency')
    plt.xticks(xpos, xlabels)
    plt.grid(True, axis='both')
    plt.ylim(0., 1.5)
    plt.subplot(2, 1, 2)
    plt.plot(all_purs)
    plt.grid(True, axis='both')
    plt.yticks(np.arange(0.,1.5, .2))
    plt.xticks(xpos, xlabels, label='Purity')
    plt.ylim(0., 1.5)
    plt.yticks(np.arange(0.,1.5, .2))
    f = output[0]
    print(type(f))
    print(f)
    plt.savefig(f)

import os
def get_angles_by_plane(plane):
    if plane == 'u':
        angles = high_end_xzu_xzv_deg_uplane
    elif plane == 'v':
        angles = high_end_xzu_xzv_deg_vplane
    elif plane == 'w':
        angles = high_end_xzw_xzu_deg_wplane
    else:
        raise RuntimeError(f'Unknown plane {plane}')
    return angles


#
# Run an a reco/true h5 pair through a model
#
plane_to_view = {'u':0, 'v':1, 'w':2}
config.setdefault('dnnapp', 'dnnroi_custom')
config.setdefault('model', '')
config.setdefault('cfg', '')
rule run_one:
    input:
        rec=lambda w : ('linedepos-pdhd-{plane}plane-t1_{t1}-t2_{t2}-g4-rec-' + f'{plane_to_view[w.plane]}.h5'),
        tru=lambda w : ('linedepos-pdhd-{plane}plane-t1_{t1}-t2_{t2}-g4-tru-' + f'{plane_to_view[w.plane]}.h5'),
    output:
        'test_line_{plane}plane_t1-{t1}-t2-{t2}.pt'
    params:
        device='cpu',
        model=config['model'],
        app=config['dnnapp'],
        cfg=config['cfg'],
    shell: """
    wcpy dnn run_one \
    {input.rec} {input.tru} \
    --app {params.app} \
    -l {params.model} \
    -c {params.cfg} \
    -o {output}
    """     


def get_input_by_plane(wildcards):
    angles = get_angles_by_plane(wildcards.plane)
    # return [os.path.join(config['test_input'], f'test_line_txzu{txzu}-txzv{txzv}.pt') for txzu, txzv in angles]
    return [
        f'test_line_{wildcards.plane}plane_t1-{t1}-t2-{t2}.pt' for t1,t2 in angles
    ]

rule plot_eff_pur:
    input:
        get_input_by_plane
    output:
        png='all_eff_pur_{plane}plane.png',
        npz='all_eff_pur_{plane}plane.npz',
    params:
        test_tpcs = [int(i) for i in config['test_tpcs']]

    run:
        import torch
        import matplotlib.pyplot as plt
        import matplotlib
        matplotlib.use('Agg')
        import numpy as np
        all_effs = []
        all_purs = []

        xlabels = [f'{u},{v}' for u,v in get_angles_by_plane(wildcards.plane)]
        xpos = [i for i in range(len(xlabels))]

        ranges = [[0,800], [800,1600], [1600,2560]]
        for f in input:
            t = torch.load(f)
            labels = t['labels'][0].detach().cpu()
            y = t['y'][0].detach().cpu()

            for plane in params.test_tpcs:
                this_range = ranges[plane]
                real_pixels = torch.where(labels[this_range[0]:this_range[1]] > 0)
                eff = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/labels[this_range[0]:this_range[1]].sum()
                all_effs.append(eff)

                pur = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/(y[this_range[0]:this_range[1]] > .5).sum()
                all_purs.append(pur)
        print(all_effs)
        print(all_purs)

        plt.subplot(2, 1, 1)
        plt.plot(all_effs, label='Efficiency')
        plt.xticks(xpos, xlabels)
        plt.grid(True, axis='both')
        plt.ylim(0., 1.5)
        plt.subplot(2, 1, 2)
        plt.plot(all_purs)
        plt.grid(True, axis='both')
        plt.yticks(np.arange(0.,1.5, .2))
        plt.xticks(xpos, xlabels, label='Purity')
        plt.ylim(0., 1.5)
        plt.yticks(np.arange(0.,1.5, .2))
        f = output.png
        print(type(f))
        print(f)
        plt.savefig(f)

        np.savez(output.npz, effs=all_effs, purs=all_purs)



all_theta_xz_deg=( 0,  1,  3,  5, 10, 20, 30, 45, 60, 75, 80, 82, 84, 89 )
all_planes = [0,1,2]

def same_thetaxz_plane_norm(txz, tyy):
    import numpy as np
    txz = txz*np.pi/180.
    tyy = tyy*np.pi/180.
    ret = np.array([1.,0.,0.])
    Ry = np.array([
        [np.cos(txz), 0, np.sin(txz)],
        [0.,1.,0.],
        [-np.sin(txz), 0, np.cos(txz)],
    ])
    Rx =  np.array([
        [1., 0., 0.],
        [0., np.cos(tyy), np.sin(tyy)],
        [0., -np.sin(tyy), np.cos(tyy)]
    ])

    return Rx @ (Ry @ ret)
def xz_y_from_xzu_xzv_hyu(xzu, xzv, tyy=-35.7):
    import numpy as np
    vu = same_thetaxz_plane_norm(xzu, tyy)
    vv = same_thetaxz_plane_norm(xzv, -tyy)
    v = np.linalg.cross(vu, vv)
    v /= np.linalg.norm(v)

    y = np.acos(v[1])
    xz = np.asin(v[0]/np.sin(y))
    return xz*180./np.pi, y*180./np.pi

high_end_xzu_xzv_deg=([75, 75], [80, 80], [82,82], [85,85], [75, 87], [85, 87], [87, 87])
high_end_xz_y_deg=(
    xz_y_from_xzu_xzv_hyu(xzu, xzv)
    for xzu, xzv in high_end_xzu_xzv_deg
)
# for xz, y in high_end_xz_y_deg:

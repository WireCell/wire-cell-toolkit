config.setdefault('test_input', 'blah')
config.setdefault('test_tpcs', [1])

def run_plot(angles):
    import torch
    import matplotlib.pyplot as plt
    import numpy as np
    all_effs = []
    all_purs = []

    xlabels = [f'{u},{v}' for u,v in angles]
    xpos = [i for i in range(len(xlabels))]

    ranges = [[0,800], [800,1600], [1600,2560]]
    for f in input:
        t = torch.load(f)
        labels = t['labels'][0].detach().cpu()
        y = t['y'][0].detach().cpu()

        for plane in params.test_tpcs:
            this_range = ranges[plane]
            real_pixels = torch.where(labels[this_range[0]:this_range[1]] > 0)
            eff = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/labels[this_range[0]:this_range[1]].sum()
            all_effs.append(eff)

            pur = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/(y[this_range[0]:this_range[1]] > .5).sum()
            all_purs.append(pur)
    print(all_effs)
    print(all_purs)

    plt.subplot(2, 1, 1)
    plt.plot(all_effs, label='Efficiency')
    plt.xticks(xpos, xlabels)
    plt.grid(True, axis='both')
    plt.ylim(0., 1.5)
    plt.subplot(2, 1, 2)
    plt.plot(all_purs)
    plt.grid(True, axis='both')
    plt.yticks(np.arange(0.,1.5, .2))
    plt.xticks(xpos, xlabels, label='Purity')
    plt.ylim(0., 1.5)
    plt.yticks(np.arange(0.,1.5, .2))
    f = output[0]
    print(type(f))
    print(f)
    plt.savefig(f)

import os
def get_angles_by_plane(plane):
    if plane == 'u':
        angles = high_end_xzu_xzv_deg_uplane
    elif plane == 'v':
        angles = high_end_xzu_xzv_deg_vplane
    return angles

def get_input_by_plane(wildcards):
    angles = get_angles_by_plane(wildcards.plane)
    return [os.path.join(config['test_input'], f'test_line_txzu{txzu}-txzv{txzv}.pt') for txzu, txzv in angles]

rule plot_eff_pur:
    input:
        get_input_by_plane
    output:
        'all_eff_pur_{plane}plane.png'
    params:
        test_tpcs = [int(i) for i in config['test_tpcs']]

    run:
        import torch
        import matplotlib.pyplot as plt
        import numpy as np
        all_effs = []
        all_purs = []

        xlabels = [f'{u},{v}' for u,v in get_angles_by_plane(wildcards.plane)]
        xpos = [i for i in range(len(xlabels))]

        ranges = [[0,800], [800,1600], [1600,2560]]
        for f in input:
            t = torch.load(f)
            labels = t['labels'][0].detach().cpu()
            y = t['y'][0].detach().cpu()

            for plane in params.test_tpcs:
                this_range = ranges[plane]
                real_pixels = torch.where(labels[this_range[0]:this_range[1]] > 0)
                eff = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/labels[this_range[0]:this_range[1]].sum()
                all_effs.append(eff)

                pur = (y[this_range[0]:this_range[1]][real_pixels] > .5).sum()/(y[this_range[0]:this_range[1]] > .5).sum()
                all_purs.append(pur)
        print(all_effs)
        print(all_purs)
    
        plt.subplot(2, 1, 1)
        plt.plot(all_effs, label='Efficiency')
        plt.xticks(xpos, xlabels)
        plt.grid(True, axis='both')
        plt.ylim(0., 1.5)
        plt.subplot(2, 1, 2)
        plt.plot(all_purs)
        plt.grid(True, axis='both')
        plt.yticks(np.arange(0.,1.5, .2))
        plt.xticks(xpos, xlabels, label='Purity')
        plt.ylim(0., 1.5)
        plt.yticks(np.arange(0.,1.5, .2))
        f = output[0]
        print(type(f))
        print(f)
        plt.savefig(f)


def get_input(wildcards):
    return os.path.join(config['test_input'], f'test_line_txzu{wildcards.txzu}-txzv{wildcards.txzv}.pt') 


rule plot_feat_y_labels:
    input:
        # 'test_line_txzu82-txzv82.pt'
        get_input
    output:
        temp('line-display-txzu{txzu}-txzv{txzv}.pickle')
    run:
        import torch
        import matplotlib
        import matplotlib.pyplot as plt
        import warnings

        # 1. Force TrueType fonts (Type 42) instead of Type 3
        matplotlib.rcParams['pdf.fonttype'] = 42
        matplotlib.rcParams['ps.fonttype'] = 42

        # 2. Aggressively suppress the warning that triggers the crash
        # This prevents the 'warn_on_missing_glyph' function from ever running
        warnings.filterwarnings("ignore", category=UserWarning, module="matplotlib")

        # 3. Use a standard font that is widely available on Linux
        plt.rcParams['font.family'] = 'DejaVu Sans'
        t = torch.load(input[0])
        feat = t['feat']; y = t['y']; labels = t['labels']
        fig, axs = plt.subplots(3,1)
        for i, f in enumerate([feat, y >.5, labels]):
            im = axs[i].imshow(f[0].detach().cpu(), aspect='auto'); plt.colorbar(im)
        # plt.title(f'XZu:{wildcards.txzu}, XZv:{wildcards.txzv}')

        f = output[0]
        # print(f)
        # plt.savefig(f)
        import pickle
        pickle.dump(fig, open(f, 'wb'))
rule plot_feat_y_labels_all:
    input:
        [f'line-display-txzu{txzu}-txzv{txzv}.pickle' for txzu, txzv in high_end_xzu_xzv_deg]
    output:
        'line-displays.tar'
    shell:
        'tar -cf {output} {input}'

rule plot_feat_y_labels_uvplane:
    input:
        lambda w: [f'line-display-txzu{txzu}-txzv{txzv}.pickle' for txzu, txzv in (high_end_xzu_xzv_deg_uplane if w.plane == 'u' else (high_end_xzu_xzv_deg_vplane))]
    output:
        'line-displays_{plane}plane.tar'
    shell:
        'tar -cf {output} {input}'

rule all_plots:
    input:
        tar='line-displays.tar',
        effpur='all_eff_pur.png'

rule all_plots_uvplane:
    input:
        tar='line-displays_{plane}plane.tar',
        effpur='all_eff_pur_{plane}plane.png'
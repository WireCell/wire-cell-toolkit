#
# Making fodder for DNNROI training, only from track and spng.
# 
# This requires a 6 digit seed starting with 1 to separate from 5 digit seeds
# allowed for "track" or "line".
TRAINING_OUTPAT = 'training-{wctier}.hdf'

rule training_fodder:
    benchmark: format_track('benchmark.txt', tier='fodder')
    input:
        format_track('data.npz', tier='depo', unit='{seed}')
    output:
        fodder = format_track(TRAINING_OUTPAT.format(wctier='fodder'), tier='fodder'),
        truth = format_track(TRAINING_OUTPAT.format(wctier='truth'), tier='fodder'),
        log = format_track('wct.log', tier='fodder') 
    params:
        cfg = f'spng/dnnroi-training.jsonnet',
        outpat = format_track(TRAINING_OUTPAT.format(wctier='%(tier)s'), tier='fodder')
    wildcard_constraints:
        seed="1[0-9]{5}"
    shell:"""
    wire-cell -l {output.log} -L debug -c {params.cfg} -A input={input} -A 'outpat={params.outpat}'
    """
    

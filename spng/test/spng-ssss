# Some helpers to generate paths in consistent way.
class FailsafeDict(dict):
    'Allow incomplete string formatting'
    def __getitem__(self, item):
        try:
            return super().__getitem__(item)
        except KeyError:
            return "{" + str(item) + "}"
def format_partial(string, **params):
    'String formatting where missing params are left in place'
    return string.format_map(FailsafeDict(params))
def format_path(path=path_base, filename=None, **params):
    if filename:
        path = path + "/" + filename
    if params.get('kind', None) in kind_unit:
        params.setdefault('unit', kind_unit[params['kind']])
    path = format_partial(path, **params)
    return path
def format_track(fname, **params):
    params.setdefault('kind', 'track')
    return format_path(filename=fname, **params)
def format_line(fname, **params):
    params.setdefault('kind', 'line')
    return format_path(filename=fname, **params)

def expand_path(path=path_base, filename=None, **params):
    d = dict(expansions_config)
    d.update(params)
    if filename:
        path = path + "/" + filename
    return expand(path, **d)

def expand_track(fname, **params):
    path = format_path(filename=fname, kind='track', unit='{unit}')
    d = dict(expansions_config)
    d.update(params)
    d.setdefault('unit', expansions_config['seed'])
    d.setdefault('tier', STATIC['tiers']['track'])
    return expand(path, **d)

def expand_line(fname, **params):
    path = format_path(filename=fname, kind='line', unit='{unit}')
    d = dict(expansions_config)
    d.update(params)
    unit = kind_unit['line']
    d.setdefault('unit', [
        unit.format(plane=p, txz=t[0], ty=t[1])
        for p,t in product(expansions_config['plane'],
                           zip(expansions_config['theta_xz_deg'], expansions_config['theta_y_deg']))])
    d.setdefault('tier', STATIC['tiers']['line'])
    ret = expand(path, **d)
    return ret


#
# Rules
# 


# In any output path we can write the implicit config for record keeping and to
# trigger rerun when someone changes any parameter.  This is used as input to
# the beginning to each kind of processing.
rule bake_implicit:
    output: path_base + '/config.txt'
    run:
        open(str(output[0]), 'w').write(json.dumps(implicit_config))


rule all_bake_implicit:
    input: expand_line('config.txt'),
           expand_track('config.txt')

#
# The track kinds run art/larsoft in a container.
#

rule track_kine:
    container: config['container']
    benchmark:
        format_track("benchmark.txt", tier='kine')
    shadow: "minimal"
    params:
        fhicl = lambda w: STATIC['track'][w.det]['kine'],
    input:
        format_track('config.txt', tier='kine')
    output:
        data = format_track('data.root', tier='kine'),
        log = format_track('lar.log', tier='kine')
    shell:
        STATIC['setup_larsoft'] + """
        mkdir -p $(dirname {output.data})
        lar --no-timing --no-memcheck -n {wildcards.nevent} -c {params.fhicl} -o {output.data} -T hist > {output.log} 2>&1
        rm -f hist
        """

rule track_step:
    container: config['container']
    benchmark:
        format_track("benchmark.txt", tier='step')
    shadow: "minimal"
    params:
        fhicl = lambda w: STATIC['track'][w.det]['step'],
    input: rules.track_kine.output.data
    output:
        data = format_track('data.root', tier='step'),
        log = format_track('lar.log', tier='step')
    shell:
        STATIC['setup_larsoft'] + """
        mkdir -p $(dirname {output.data})
        lar --no-timing --no-memcheck -c {params.fhicl} {input} -o {output.data} -T hist > {output.log} 2>&1
        rm -f hist
        """

# {det}/track/depo/{seed}/{nevent}/*
rule track_depo:
    container: config['container']
    benchmark:
        format_track("benchmark.txt", tier='depo')
    shadow: "minimal"
    params:
        fhicl = lambda w: STATIC['track'][w.det]['depo'],
    input:
        steps = rules.track_step.output.data,
        jsonnet = lambda w: STATIC['track'][w.det]['depo_jsonnet']
    output:
        data = format_track('data.npz', tier='depo'),
        log = format_track('lar.log', tier='depo')
    shell:
        STATIC['setup_larsoft'] + """
        export WIRECELL_PATH={FCL_DIR}:$WIRECELL_PATH
        mkdir -p $(dirname {output.data})
        lar --no-timing --no-memcheck -c {params.fhicl} {input.steps} --no-output > {output.log} 2>&1
        mv wct-depos.npz {output.data}
        """

#
# The line kinds run use wcpy to make depos directly
# 
rule line_depo:
    input:
        format_line('config.txt', tier='depo')
    output:
        depos=format_line('data.npz', tier='depo'),
        meta=format_line('meta.json', tier='depo')
    params:
        offset = lambda w: STATIC['spdir'][w.det]['offset'],
    shell: '''
    wcpy gen detlinegen \
    {params.offset} \
    --detector={wildcards.det} \
    --plane={wildcards.plane} \
    --angle-coords=wire-plane \
    --theta_xz="{wildcards.txz}*deg" \
    --theta_y="{wildcards.ty}*deg" \
    --output_depos {output.depos} \
    --output_meta {output.meta}
    '''

rule all_line_depo:
    input:
        expand_line('data.npz', tier=['depo'])

        

#
# Both track and line kinds process depos through some common bits.
#
# Post-depo rules.
for kind in ('line', 'track'):
    for src, tgt in STATIC['wct']['stages']:
        src_path = format_path(kind=kind, tier=src)
        tgt_path = format_path(kind=kind, tier=tgt)
        rule:
            name: f'{kind}_{src}_to_{tgt}'
            benchmark: tgt_path + '/benchmark.txt'
            input: src_path + '/data.npz'
            output:
                out = tgt_path + '/data.npz',
                log = tgt_path + '/wct.log'
            params:
                cfg = f'spng/{src}-to-{tgt}.jsonnet'
            shell: """
            wire-cell -l {output.log} -L debug -c {params.cfg} -A input={input} -A output={output.out}
            """
    


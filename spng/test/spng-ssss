        '''

    checkpoint:
        name: f'collect_metrics_{sig}'
        input: expand_line('metrics.json', tier=sig)
        output:
            format_path(filename='metrics.done', kind='line', tier=sig, unit='summary')
        shell: """
        mkdir -p $(dirname {output})
        touch {output}
        """

    rule:
        name: f'metric_plots_{sig}'
        input:
            ready = getattr(rules, f'collect_metrics_{sig}').output,
            metrics = getattr(rules, f'collect_metrics_{sig}').input
        output:

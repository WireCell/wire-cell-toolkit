# Default values to expand over in all_* rules.
EXPANSIONS = {
    # List of WCT canonical detector names to expand over.
    "det": ["pdhd"],

    # Note: we do not list 'kind' nor 'tier' here as the two span a non
    # rectangular configuration space.  Only some tier for all kind.

    # The number of "events" to produce.  Technically, this could be given as a
    # list of length greater than one, eg [10,100], generally one wants only one
    # value.  We put it here because nevents goes into the path rather than
    # being something we'd want to expand upon.  Note, something besides 1 only
    # matters for output under {det}/track/.
    "nevent": [1],

    # The random number generator seeds to expand as track "units".  This is
    # used in an outer product with nevent so we can balance how many and how
    # large jobs should be.
    "seed": [12345],

    # Plane index arrays form outer product with matched arrays of track angles
    # in the expansion for line units.
    # The plane indices
    "plane": [0, 1, 2],
    # Wire-plane angle from Y axis to track direction
    'theta_y_deg': ( 90, 90, 90, 90, 90, 90, 90, 90, 90, 90, 90, 90, 90, 90 ),
    # Wire-plane angle from X axis to projection of track into X-Z plane

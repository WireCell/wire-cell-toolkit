#!/usr/bin/env -S snakemake  --software-deployment-method apptainer --apptainer-args=" -B /cvmfs,/home,/nfs,/opt,/run/user,/etc/hostname,/etc/hosts,/etc/krb5.conf --ipc --pid" --cores 16 --snakefile
# -*- snakemake -*-

# This snakemake workflow runs just about every type of job that relates to SPNG.

# You must run this from a working WCT environment.  Some special attention:
# - WIRECELL_PATH should include the path to spng/cfg/
# - OMP_NUM_THREADS=1 or other value if you want to limit libtorch threading

# CVMFS is also needed for running larsoft rules.

# Files are produced in a tree relative to the directory given by --directory and 
# with this wildcard pattern:
#
path_base = '{det}/{kind}/{tier}/{unit}/{nevent}'

# {det} names the detector.  One in {pdhd,} (for now).
# {kind} states what kind of processing the file comes from.  One in: {"track", "line"}
# {tier} depends on "kind" and defines the stage that produced the files.
# - Some tiers are common to all kinds such as: {kine, step, depo, adc, splat, osp, spng}
# - Unique tiers for "line" include: {metric, plot, mplot}
# {unit} depends the "kind" and names some variant.

# Note: all labels are singular, not plural.

# Note: there is some non-orthogonal use of these path labels.
# - kind=line: nevent is not meaningful and will take whatever value.
# - kind=line: the 'unit" names each line direction and a 'unit=summary' folds over these.

kind_unit = {
    #  - In "tracks", for individual sets of tracks, it is defined as:
    'track': '{seed}',
    #  - In "line", for individual lines, it is defined as:
    'line': 'p{plane}-txz{txz}-ty{ty}',
}

# Files under path_base are named simply and generically just enough to
# distinguish them inside that context and to allow symmetry across some rules.
# Examples include, "data.npz", "lar.log".
#
# A set of configuration parameters can be provided and they fall into two
# distinct roles:
#
# 1. Provide list of values over which a wildcard parameter is expanded in an
# "all_*" rule.  These values may be general or depend on the "kind" of
# processing.
#
# For example, this would expand the "unit" for "track" kind.
#
#   --config seeds=[12345,23456]
#
# Note, special seeds for producing training fodder are 6 digits in [1e6,2e6).
# Avoid using this seeds range to produce input for inference.

#
# While this expands to produce two kinds of output
#
#   --config kinds=["track","line"]
#
# Note: these expansions only make sense for running Snakemake with a named
# "all_*" target.  If running Snakemake to produce a specific path, these
# configuration parameters are fully vestigial.
#
# 2. Provide implicit and scalar values for parameters that are not reflected
# into the output paths.  These are parameters whose values generally should not
# change the output results.  They include "device" and "container".
#
# All configuration parameters have minimal working defaults.
#

# Example calls:
# $ ./spng/test/spng-ssss all_metrics


import os

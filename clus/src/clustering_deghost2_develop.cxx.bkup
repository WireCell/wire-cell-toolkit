    std::string filename = "cluster_coverage_distances_apa" + std::to_string(APA) + ".txt";
    if(coverage_results.size() > 0) {

    std::ofstream outfile(filename);
    if (outfile.is_open()) {
        outfile << "# Cluster Coverage Analysis with 3D/2D Distances, Lengths, and Time Slice Ranges\n";
        outfile << "# Format: cluster1_id cluster2_id coverage_plane nearest_3d_distance_cm nearest_2d_distance_cm "
                << "cluster1_length_cm cluster2_length_cm cluster1_time_min cluster1_time_max cluster2_time_min "
                << "cluster2_time_max covered_points total_points coverage_ratio\n";
        outfile << "# cluster1 covers cluster2 in the specified plane\n";
        outfile << "# nearest_3d_distance_cm: minimum 3D distance between any points in the two clusters\n";
        outfile << "# nearest_2d_distance_cm: minimum 2D distance in the covered projection plane\n";
        outfile << "# cluster1_length_cm: length of covering cluster, cluster2_length_cm: length of covered cluster\n";
        outfile << "# cluster1_time_min/max: time slice range for covering cluster (from get_uvwt_min/max)\n";
        outfile << "# cluster2_time_min/max: time slice range for covered cluster (from get_uvwt_min/max)\n";
        outfile << std::fixed << std::setprecision(6);
        
        for (const auto& info : coverage_results) {
            // if(APA==3&&info.cluster1_id ==221&&info.cluster2_id ==202){
            // if(APA==3&&info.cluster1_id ==32){
            // std::cout<< info.nearest_3d_distance / units::cm<<std::endl;
            // if(info.cluster1_length / units::cm > 415 && info.cluster1_length / units::cm < 415.5
            //     && info.cluster2_length / units::cm > 97.9 && info.cluster2_length / units::cm <98){
            if(info.cluster1_time_min == 0 && info.cluster1_time_max == 2983
                && info.cluster2_time_min == 404 && info.cluster2_time_max == 467){
            // if(APA==3){
               index_to_cluster_map[info.cluster1_id]->set_scope_filter(scope, false); 
               index_to_cluster_map[info.cluster2_id]->set_scope_filter(scope, false); 
               std::cout<<"GOT IT!!"<<std::endl;
            }
            outfile << info.cluster1_id << " " 
                    << info.cluster2_id << " " 
                    << info.coverage_plane << " " 
                    << info.nearest_3d_distance / units::cm << " "  // Convert to cm
                    << info.nearest_2d_distance / units::cm << " "      // NEW: Convert to cm
                    << info.cluster1_length / units::cm << " "          // NEW: Convert to cm
                    << info.cluster2_length / units::cm << " " 
                    << info.cluster1_time_min << " "                    // NEW: Time slice (integer)
                    << info.cluster1_time_max << " "                    // NEW: Time slice (integer)
                    << info.cluster2_time_min << " "                    // NEW: Time slice (integer)
                    << info.cluster2_time_max << " "          // NEW: Convert to cm
                    << info.covered_points << " " 
                    << info.total_points << " " 
                    << info.coverage_ratio << "\n";
        }
        outfile.close();
        std::cout << "Coverage results with 3D distances saved to cluster_coverage_distances.txt" << std::endl;
        std::cout << "Total coverage cases found: " << coverage_results.size() << std::endl;
    } else {
        std::cerr << "Error: Could not open output file cluster_coverage_distances.txt" << std::endl;
    }

    }


// bool Cluster::construct_skeleton(IDetectorVolumes::pointer dv, IPCTransformSet::pointer pcts, const bool use_ctpc)
// {

static std::pair<size_t, size_t> skeleton_points_hilo(const Cluster& cluster)
{
    geo_point_t highest_wcp = cluster.point3d(0);
    geo_point_t lowest_wcp = cluster.point3d(0);
    size_t highest_index = 0;
    size_t lowest_index = 0;

    geo_point_t main_dir = cluster.get_pca().axis.at(0);
    main_dir = main_dir.norm();
    geo_point_t center = cluster.get_pca().center;
    geo_point_t temp_pt(highest_wcp.x() - center.x(), highest_wcp.y() - center.y(), highest_wcp.z() - center.z());
    double highest_value = temp_pt.dot(main_dir);
    double lowest_value = highest_value;

    for (int i = 1; i < cluster.npoints(); i++) {
        temp_pt.set(cluster.point3d(i).x() - center.x(),
                    cluster.point3d(i).y() - center.y(),
                    cluster.point3d(i).z() - center.z());
        double value = temp_pt.dot(main_dir);
        if (value > highest_value) {
            highest_value = value;
            highest_wcp = cluster.point3d(i);
            highest_index = i;
        }
        else if (value < lowest_value) {
            lowest_value = value;
            lowest_wcp = cluster.point3d(i);
            lowest_index = i;
        }
    }
    std::cout << "highest point: " << highest_wcp << " lowest point: " << lowest_wcp << std::endl;
    return std::make_pair(highest_index, lowest_index);
}
std::pair<int, int> get_cluster_time_range(const Cluster* cluster, int apa, int face) {
    // Use the existing get_uvwt_min and get_uvwt_max functions with specific APA and face
    // These return tuples (u_min, v_min, w_min, t_min) and (u_max, v_max, w_max, t_max)
    const auto uvwt_min = cluster->get_uvwt_min(apa, face);
    const auto uvwt_max = cluster->get_uvwt_max(apa, face);
    
    // Extract time slice values (4th element of tuple)
    int t_min = std::get<3>(uvwt_min);
    int t_max = std::get<3>(uvwt_max);
    
    return {t_min, t_max};
}

double calculate_nearest_3d_distance(const Cluster* cluster1, const Cluster* cluster2) {
    if (cluster1->npoints() == 0 || cluster2->npoints() == 0) {
        return -1.0; // Invalid distance
    }
    
    // Use the existing get_closest_points method which returns:
    // std::tuple<int, int, double> - (index1, index2, distance)
    std::tuple<int, int, double> results = cluster1->get_closest_points(*cluster2);
    double nearest_distance = std::get<2>(results);
    
    return nearest_distance;
}

struct CoverageInfo {
    int cluster1_id;
    int cluster2_id;
    std::string coverage_plane;
    double nearest_3d_distance;
    double nearest_2d_distance;      // NEW: nearest 2D distance in the covered plane
    double cluster1_length;          // NEW: length of cluster1 (covering cluster)
    double cluster2_length; 
    int cluster1_time_min;           // NEW: minimum time slice for cluster1
    int cluster1_time_max;           // NEW: maximum time slice for cluster1
    int cluster2_time_min;           // NEW: minimum time slice for cluster2
    int cluster2_time_max; 
    int covered_points;
    int total_points;
    double coverage_ratio;
};

static std::vector<size_t> get_path_wcps(const Cluster& cluster, 
                                         IDetectorVolumes::pointer dv,
                                         IPCTransformSet::pointer pcts,
                                         bool use_ctpc)
{
    auto [hi, lo] = skeleton_points_hilo(cluster);
    if (use_ctpc) {
        return cluster.graph_algorithms("ctpc", dv, pcts).shortest_path(hi, lo);
    }
    else {
        return cluster.graph_algorithms().shortest_path(hi, lo);
    }
}



static void clustering_deghost(Grouping& live_grouping,
                               IDetectorVolumes::pointer dv,
                               IPCTransformSet::pointer pcts,
                               const Tree::Scope& scope,
                               const bool use_ctpc,
                               double length_cut = 0,
                               double length_threshold = 5*units::cm,
                               double coverage_threshold = 0.8);

class ClusteringDeghost2 : public IConfigurable, public Clus::IEnsembleVisitor, private NeedDV, private NeedPCTS, private NeedScope {
public:
    ClusteringDeghost2() {}
    virtual ~ClusteringDeghost2() {}

    void configure(const WireCell::Configuration& config) {
        NeedDV::configure(config);
        NeedPCTS::configure(config);
        NeedScope::configure(config);
        
        use_ctpc_ = get(config, "use_ctpc", true);
        length_cut_ = get(config, "length_cut", 5.0*units::cm);
        length_threshold_ = get(config, "length_threshold", 5.0*units::cm);
        coverage_threshold_ = get(config, "coverage_threshold", 0.9); // 90% coverage
    }
    virtual Configuration default_configuration() const {
        Configuration cfg;
        return cfg;
    }
    
    void visit(Ensemble& ensemble) const {
        auto& live = *ensemble.with_name("live").at(0);
        std::cout<<"deghost2 test!!!!!!!"<<std::endl;
        clustering_deghost(live, m_dv, m_pcts, m_scope,  use_ctpc_, length_cut_,length_threshold_,coverage_threshold_);
    }
    
private:
    double use_ctpc_{true};
    double length_cut_{5.0*units::cm}; // 5 cm
    double length_threshold_{5.0*units::cm}; // 5 cm
    double coverage_threshold_{0.9}; // 90%
};



                    geo_point_t point2 = cluster2->point3d(pt_idx);
                     auto test_wpid = cluster2->wire_plane_id(pt_idx); // Get wire plane info for the point
                    // Add these lines here (around line 454)
                    // std::cout << "  Debugging search parameters for point_idx " << pt_idx << ":" << std::endl;
                    // std::cout << "    point2: (" << point2.x() << ", " << point2.y() << ", " << point2.z() << ")" << std::endl;
                    // std::cout << "    test_wpid.face(): " << test_wpid.face() << std::endl;
                    // std::cout << "    test_wpid.apa(): " << test_wpid.apa() << std::endl;
                    // std::cout << "    view_id for V plane search: 1" << std::endl; // Explicitly state the view_id being used

                    std::tuple<double, const Cluster *, size_t> results_v =
                        temp_pc_cluster1->get_closest_2d_point_info(point2, 1, test_wpid.face(), test_wpid.apa());
                    double nearest_dist_v = std::get<0>(results_v);
                    // std::cout << "    Debugging results_v: distance = " << std::get<0>(results_v) << " cm"
                    //           << ", cluster_ptr = " << std::get<1>(results_v)
                    //           << ", point_index = " << std::get<2>(results_v) << std::endl;
                    if (nearest_dist_v>0 && nearest_dist_v < length_threshold) {
                        covered_points_v++;
                    }
                    if (nearest_dist_v > 0 && nearest_dist_v < min_2d_distance_v) {
                        min_2d_distance_v = nearest_dist_v;
                    }

                }
                double coverage_ratio_v = (double)covered_points_v / cluster2->npoints();
                if ((double)covered_points_v / cluster2->npoints() >= coverage_threshold) {
                    std::cout<<map_cluster_index[cluster2] <<" is covered by "<<map_cluster_index[cluster1]<<" covered in v: " << covered_points_v << " / " << cluster2->npoints() << std::endl;
                    covered_in_v = true;
                    // std::get<1>(cluster_cover_map[cluster2]) = 1;
                    std::get<1>(cluster_cover_map[cluster2]).push_back(map_cluster_index[cluster1]);
                    // cluster2->set_scope_filter(scope, false);
                    coverage_planes.push_back("V");
                    double nearest_3d_dist = calculate_nearest_3d_distance(cluster1, cluster2);
                    CoverageInfo info;
                    info.cluster1_id = map_cluster_index[cluster1];
                    info.cluster2_id = map_cluster_index[cluster2];
                    info.coverage_plane = "V";
                    info.nearest_3d_distance = nearest_3d_dist;
                    info.nearest_2d_distance = min_2d_distance_v;        // NEW: Use tracked minimum
                    info.cluster1_length = cluster1->get_length();        // NEW
                    info.cluster2_length = cluster2->get_length();        // NEW
                    info.cluster1_time_min = time1_min;                   // NEW
                    info.cluster1_time_max = time1_max;                   // NEW
                    info.cluster2_time_min = time2_min;                   // NEW
                    info.cluster2_time_max = time2_max;
                    info.covered_points = covered_points_v;
                    info.total_points = cluster2->npoints();
                    info.coverage_ratio = coverage_ratio_v;
                    coverage_results.push_back(info);
                }

                // Check coverage in W projection (view_id 2)
                int covered_points_w = 0;
                double min_2d_distance_w = 1e9;
                for (size_t pt_idx = 0; pt_idx < cluster2->npoints(); ++pt_idx) {
                    geo_point_t point2 = cluster2->point3d(pt_idx);
                     auto test_wpid = cluster2->wire_plane_id(pt_idx); // Get wire plane info for the point
                        // if(test_wpid.apa()==3){
                        //     std::cout<< "Test: point2: " << point2 << " test_wpid.face(): " << test_wpid.face() 
                        //               << " test_wpid.apa(): " << test_wpid.apa() << std::endl;
                        // }
                    std::tuple<double, const Cluster *, size_t> results_w =
                        temp_pc_cluster1->get_closest_2d_point_info(point2, 2, test_wpid.face(), test_wpid.apa());

                    // Add these lines here (around line 454)
                    // std::cout << "  Debugging search parameters for point_idx " << pt_idx << ":" << std::endl;
                    // std::cout << "    point2: (" << point2.x() << ", " << point2.y() << ", " << point2.z() << ")" << std::endl;
                    // std::cout << "    test_wpid.face(): " << test_wpid.face() << std::endl;
                    // std::cout << "    test_wpid.apa(): " << test_wpid.apa() << std::endl;
                    // std::cout << "    view_id for W plane search: 2" << std::endl; // Explicitly state the view_id being used


                    double nearest_dist_w = std::get<0>(results_w);
                                            // To inspect results_w (tuple content)
                    // std::cout << "    Debugging results_w: distance = " << std::get<0>(results_w) << " cm"
                    //           << ", cluster_ptr = " << std::get<1>(results_w)
                    //           << ", point_index = " << std::get<2>(results_w) << std::endl;
                    if (nearest_dist_w>0 && nearest_dist_w < length_threshold) {
                        covered_points_w++;
                    }
                    if (nearest_dist_w > 0 && nearest_dist_w < min_2d_distance_w) {
                        min_2d_distance_w = nearest_dist_w;
                    }
                }
                double coverage_ratio_w = (double)covered_points_w / cluster2->npoints();
                if ((double)covered_points_w / cluster2->npoints() >= coverage_threshold) {
                    std::cout<<map_cluster_index[cluster2] <<" is covered by "<<map_cluster_index[cluster1]<<" covered in w: " << covered_points_w << " / " << cluster2->npoints() << std::endl;
                    covered_in_w = true;
                    // std::get<2>(cluster_cover_map[cluster2]) = 1;
                    std::get<2>(cluster_cover_map[cluster2]).push_back(map_cluster_index[cluster1]);
                    // cluster2->set_scope_filter(scope, false);
                    // auto it = cluster_cover_map.find(cluster2);
                    // if (it != cluster_cover_map.end()) {
                    //     // Access the tuple via the iterator and modify the element
                    //     std::get<2>(it->second) = 1;
                    // } else {
                    //     // Handle the case where cluster2 is not found (shouldn't happen based on your init code, but good practice)
                    //     std::cerr << "Error: cluster2 not found in cluster_cover_map!" << std::endl;
                    // }
                    coverage_planes.push_back("W");
                    double nearest_3d_dist = calculate_nearest_3d_distance(cluster1, cluster2);
                    CoverageInfo info;
                    info.cluster1_id = map_cluster_index[cluster1];
                    info.cluster2_id = map_cluster_index[cluster2];
                    info.coverage_plane = "W";
                    info.nearest_3d_distance = nearest_3d_dist;
                    info.nearest_2d_distance = min_2d_distance_w;        // NEW: Use tracked minimum
                    info.cluster1_length = cluster1->get_length();        // NEW
                    info.cluster2_length = cluster2->get_length();    
                    info.cluster1_time_min = time1_min;                   // NEW
                    info.cluster1_time_max = time1_max;                   // NEW
                    info.cluster2_time_min = time2_min;                   // NEW
                    info.cluster2_time_max = time2_max;
                    info.covered_points = covered_points_w;
                    info.total_points = cluster2->npoints();
                    info.coverage_ratio = coverage_ratio_w;
                    coverage_results.push_back(info);
                }
            }
            // exit(0);

            // If cluster2 is covered by cluster1 in any projection, mark cluster2 for removal

            // if (covered_in_u || covered_in_v || covered_in_w) {
                // to_be_removed_clusters.push_back(cluster2);
            // }
        }
        // break; // Only process the longest cluster
    }
    // int count=0;

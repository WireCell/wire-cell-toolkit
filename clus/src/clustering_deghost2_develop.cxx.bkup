// This can handle entire APA (including all faces) data
static void clustering_deghost(
    Grouping& live_grouping,
    IDetectorVolumes::pointer dv,
    IPCTransformSet::pointer pcts,
    const Tree::Scope& scope,
    const bool use_ctpc, 
    double length_cut,
    double length_threshold,
    double coverage_threshold)
{
    std::cout << "ClusteringDeghost2: length_cut: " << length_cut/units::cm << " length_threshold: " << length_threshold/units::cm << " coverage_threshold: " << coverage_threshold << std::endl;
    // Get all the wire plane IDs from the grouping
    const auto& wpids = live_grouping.dv_wpids();
    // Key: pair<APA, face>, Value: drift_dir, angle_u, angle_v, angle_w
    std::map<WirePlaneId , std::tuple<geo_point_t, double, double, double>> wpid_params;
    std::set<int> apas;

    // std::map<int, std::map<int, std::map<int, std::pair<double, double>>>> af_dead_u_index; 
    // std::map<int, std::map<int, std::map<int, std::pair<double, double>>>> af_dead_v_index; 
    // std::map<int, std::map<int, std::map<int, std::pair<double, double>>>> af_dead_w_index; 

    for (const auto& wpid : wpids) {
        std::cout << "DEBUG: wpid: " << wpid.apa()<< " face: "<<wpid.face()<< std::endl;
        int apa = wpid.apa();
        int face = wpid.face();
        apas.insert(apa);

        // Create wpids for all three planes with this APA and face
        WirePlaneId wpid_u(kUlayer, face, apa);
        WirePlaneId wpid_v(kVlayer, face, apa);
        WirePlaneId wpid_w(kWlayer, face, apa);
     
        // Get drift direction based on face orientation
        int face_dirx = dv->face_dirx(wpid_u);
        geo_point_t drift_dir(face_dirx, 0, 0);
        
        // Get wire directions for all planes
        Vector wire_dir_u = dv->wire_direction(wpid_u);
        Vector wire_dir_v = dv->wire_direction(wpid_v);
        Vector wire_dir_w = dv->wire_direction(wpid_w);

        // Calculate angles
        double angle_u = std::atan2(wire_dir_u.z(), wire_dir_u.y());
        double angle_v = std::atan2(wire_dir_v.z(), wire_dir_v.y());
        double angle_w = std::atan2(wire_dir_w.z(), wire_dir_w.y());

        wpid_params[wpid] = std::make_tuple(drift_dir, angle_u, angle_v, angle_w);


        // af_dead_u_index[apa][face] = live_grouping.get_dead_winds(apa, face, 0);
        // af_dead_v_index[apa][face] = live_grouping.get_dead_winds(apa, face, 1);
        // af_dead_w_index[apa][face] = live_grouping.get_dead_winds(apa, face, 2);
    }

    if (apas.size() > 1) {
        raise<ValueError>("apas.size() %d > 1", apas.size());
    }
  

    int APA = *apas.begin();
    std::vector<Cluster *> live_clusters = live_grouping.children();  // copy

    // sort the clusters by length using a lambda function
    std::sort(live_clusters.begin(), live_clusters.end(), [](const Cluster *cluster1, const Cluster *cluster2) {
        return cluster1->get_length() > cluster2->get_length();
    });

    // auto global_point_cloud_legacy = std::make_shared<DynamicPointCloudLegacy>(angle_u, angle_v, angle_w);
    auto global_point_cloud = std::make_shared<DynamicPointCloud>(wpid_params);
    // auto global_skeleton_cloud = std::make_shared<DynamicPointCloudLegacy>(angle_u, angle_v, angle_w);
    auto global_skeleton_cloud = std::make_shared<DynamicPointCloud>(wpid_params);
    // replace with the new DynamicPointCloud class

    std::vector<Cluster *> to_be_removed_clusters;
    // std::set<std::pair<Cluster *, Cluster *>> to_be_merged_pairs;
    cluster_connectivity_graph_t  g;
    std::unordered_map<int, int> ilive2desc;  // added live index to graph descriptor
    std::map<const Cluster*, int> map_cluster_index;
    for (const Cluster* live : live_grouping.children()) {
        size_t ilive = map_cluster_index.size();
        // size_t ilive = live->get_cluster_id(); // Use cluster ID as index
        map_cluster_index[live] = ilive;
        ilive2desc[ilive] = boost::add_vertex(ilive, g);
    }

    std::map<int, Cluster*> index_to_cluster_map;
    for (const auto& [cluster_ptr, cluster_id] : map_cluster_index) {
        index_to_cluster_map[cluster_id] = const_cast<Cluster*>(cluster_ptr);
    }
    std::map<Cluster*, std::tuple<std::vector<int>, std::vector<int>, std::vector<int>>> cluster_cover_map;
    std::vector<int> init_vec;
    std::tuple<std::vector<int>, std::vector<int>, std::vector<int>> init_tuple(init_vec, init_vec, init_vec);
    for (size_t i = 0; i < live_clusters.size(); ++i) {
        Cluster* cluster2 = live_clusters.at(i); 
        cluster_cover_map[cluster2] = init_tuple; // Initialize coverage counts for cluster2
    }
    std::vector<CoverageInfo> coverage_results;

    // for (size_t i = 0; i != live_clusters.size(); i++){
    //     if(live_clusters.at(i)->get_length()<200*units::cm && live_clusters.at(i)->npoints()>150){
    //         auto [hi, lo] = skeleton_points_hilo(*live_clusters.at(i));
    //         std::cout<<"Cluster " << i << " length: " << live_clusters.at(i)->get_length() / units::cm << " cm, "
    //                  << "highest index: " << hi << ", lowest index: " << lo << std::endl;
    //         std::cout<<map_cluster_index[live_clusters.at(i)] <<std::endl;
    //     } 
    // }

    // Cluster *cluster = index_to_cluster_map[221];
    // if(cluster!= nullptr){
    //     to_be_removed_clusters.push_back(cluster);
    // }
    // else{
    //     std::cout << "Test: cluster is null" << std::endl;
    // }
    



    // Iterate through all pairs of live clusters
    for (size_t i = 0; i < live_clusters.size(); ++i) {
        if(live_clusters.at(i)->get_length() < length_cut) continue; // Skip clusters shorter than length_cut

        Cluster* cluster1 = live_clusters.at(i);
           cluster1->set_scope_filter(scope, true); 
        // std::cout<<"Processing cluster "<<map_cluster_index[cluster1]<<" length: "<<cluster1->get_length()/units::cm<<" cm, npoints: "<<cluster1->npoints()<<std::endl;
        // Create a DynamicPointCloud for cluster1
        auto temp_pc_cluster1 = std::make_shared<DynamicPointCloud>(wpid_params);
        if (cluster1->npoints() > 0) {
             temp_pc_cluster1->add_points(make_points_cluster(cluster1, wpid_params, true));

        } else {
            continue; // Skip if cluster1 has no points
        }

            // cluster1->set_scope_filter(scope, false);

        for (size_t j = i+1; j < live_clusters.size(); ++j) {
            if(live_clusters.at(j)->get_length() < length_cut ||live_clusters.at(j)== cluster1) continue; // Skip clusters shorter than length_cut


            Cluster* cluster2 = live_clusters.at(j);
            // cluster2->set_scope_filter(scope, true);
            std::vector<std::string> coverage_planes;
            // std::cout<<"Processing cluster "<<map_cluster_index[cluster2]<<" length: "<<cluster2->get_length()/units::cm<<" cm, npoints: "<<cluster2->npoints()<<std::endl;

            // Skip if cluster2 is already marked for removal (to avoid redundant checks)
            // bool already_marked = false;
            // for(const auto& removed_cluster : to_be_removed_clusters) {
            //     if (cluster2 == removed_cluster) {
            //         already_marked = true;
            //         break;
            //     }
            // }
            // if (already_marked) continue;

            // Check if cluster2 is covered by cluster1 in any projection
            bool covered_in_u = false;
            bool covered_in_v = false;
            bool covered_in_w = false;
            
            if (cluster2->npoints() > 0) {
                // Check coverage in U projection (view_id 0)
                    auto first_wpid = cluster2->wire_plane_id(0);
                    int apa = first_wpid.apa();
                    int face = first_wpid.face();
                    auto [time1_min, time1_max] = get_cluster_time_range(cluster1, apa, face);
                    auto [time2_min, time2_max] = get_cluster_time_range(cluster2, apa, face);
                int covered_points_u = 0;
                double min_2d_distance_u = 1e9; 
                for (size_t pt_idx = 0; pt_idx < cluster2->npoints(); ++pt_idx) {
                    geo_point_t point2 = cluster2->point3d(pt_idx);
                    auto test_wpid = cluster2->wire_plane_id(pt_idx); // Get wire plane info for the point

                    std::tuple<double, const Cluster *, size_t> results_u =
                        temp_pc_cluster1->get_closest_2d_point_info(point2, 0, test_wpid.face(), test_wpid.apa());
                    double nearest_dist_u = std::get<0>(results_u);

                    if ( nearest_dist_u>0 && nearest_dist_u < length_threshold) {
                        covered_points_u++;
                    }

                    if (nearest_dist_u > 0 && nearest_dist_u < min_2d_distance_u) {
                            min_2d_distance_u = nearest_dist_u;
                    }  
                }
                double coverage_ratio_u = (double)covered_points_u / cluster2->npoints();
                if (coverage_ratio_u >= coverage_threshold) {

                    // std::get<0>(cluster_cover_map[cluster2]) = 1;
                    std::get<0>(cluster_cover_map[cluster2]).push_back(map_cluster_index[cluster1]);
                    covered_in_u = true;
                    coverage_planes.push_back("U");

include(CMakeFindDependencyMacro)

# Re-discover WCT's external dependencies and recreate the WCT::<TOKEN> wrapper
# targets that the exported WireCell::* targets reference, so consumers inherit
# them transitively.  This block is generated from the build's discovered set.
@WCT_EXPORT_FIND_BLOCK@

# The exported imported targets (WireCell::Util, WireCell::Aux, ...).
include("${CMAKE_CURRENT_LIST_DIR}/WireCellTargets.cmake")

# Convenience aggregate over the public libraries (mirrors the pkg-config .pc).
if(NOT TARGET WireCell::WireCell)
  add_library(WireCell::WireCell INTERFACE IMPORTED)
  set(_wct_agg)
  foreach(_t Aux Iface Util)
    if(TARGET WireCell::${_t})
      list(APPEND _wct_agg WireCell::${_t})
